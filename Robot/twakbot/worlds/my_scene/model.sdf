<sdf version="1.6">
  <model name="my_scene">
    <static>true</static>

    <link name="link">
      <visual name="visual">
        <geometry>
          <mesh>
            <uri>model://my_scene/meshes/test.obj</uri>
          </mesh>
        </geometry>
      </visual>

      <collision name="collision">
        <geometry>
          <mesh>
            <uri>model://my_scene/meshes/test.mtl</uri>
          </mesh>
        </geometry>
      </collision>
    </link>
  </model>
</sdf>